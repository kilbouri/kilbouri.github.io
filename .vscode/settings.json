{
  "css.customData": [".vscode/css_custom_data.json"],
  "editor.tabSize": 2,
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/node_modules": true,
    "**/*.d.ts": true,
    "**/tsconfig.json": true
  },
  "files.associations": {
    "*.css": "postcss"
  }
}
